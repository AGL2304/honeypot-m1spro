# Copier en .env et remplir. Ne jamais committer .env.

# PostgreSQL
POSTGRES_USER=honeypot
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=honeypot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Analyzer API
ANALYZER_URL=http://analyzer:8000

# Enrichissement Threat Intel (quotas fournis par l'école)
ABUSEIPDB_API_KEY=
GEOIP_DB_PATH=/data/geoip/GeoLite2-City.mmdb

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_admin

# Ports hote (configurables : utile si un port bas est deja pris).
# Defauts standard : SSH 22, HTTP 8080, FTP 21, Telnet 23.
# Ex. WSL/Kali ou le 80 est pris -> laisser 8080 ; pour exposer en 80 : HTTP_PORT=80
SSH_PORT=22
HTTP_PORT=8080
FTP_PORT=21
TELNET_PORT=23

# FTP mode passif : plage de ports data (doit etre publiee a l'identique).
# FTP_PASV_MIN=30000
# FTP_PASV_MAX=30009
# Adresse annoncee au client en mode passif (NAT / Docker distant).
# FTP_MASQUERADE_ADDRESS=

# secure_app (API REST securisee, fil rouge SDLC) — OBLIGATOIRE en prod.
# Sans secret fort (min. 32 car.), le conteneur refuse de demarrer (fail-closed).
# Generer : python -c "import secrets; print(secrets.token_urlsafe(48))"
SECURE_APP_SECRET_KEY=change_me_min_32_chars_random_value_here
SECURE_APP_PORT=8001
SECURE_APP_ALLOWED_ORIGINS=http://localhost:3000
