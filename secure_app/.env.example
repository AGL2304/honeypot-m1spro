# secure_app — variables d'environnement (J3/J5 : aucun secret en dur)
# Copier en .env (gitignoré) et adapter. Ne JAMAIS committer de vraie valeur.

# Environnement : "dev" (clé éphémère tolérée) ou "prod" (secret OBLIGATOIRE).
SECURE_APP_ENV=dev

# Secret de signature JWT — min. 32 caractères aléatoires.
# Générer : python -c "import secrets; print(secrets.token_urlsafe(48))"
# En prod, son absence empêche le démarrage (fail-closed).
SECURE_APP_SECRET_KEY=change_me_min_32_chars_random_value_here

# Durées de vie des jetons (secondes). Access court + refresh long.
SECURE_APP_ACCESS_TTL=900
SECURE_APP_REFRESH_TTL=604800

# Base SQLite (requêtes paramétrées partout).
SECURE_APP_DB_PATH=secure_app.db

# CORS — whitelist stricte, séparée par des virgules. JAMAIS "*" avec credentials.
SECURE_APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting du login (anti brute-force).
SECURE_APP_LOGIN_MAX_ATTEMPTS=5
SECURE_APP_LOGIN_WINDOW=60

# Argon2id (memory-hard). Réduire en CI/dev pour la vitesse, durcir en prod.
SECURE_APP_ARGON2_TIME=3
SECURE_APP_ARGON2_MEMORY=65536
SECURE_APP_ARGON2_PAR=4
